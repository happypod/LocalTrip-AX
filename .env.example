DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-strong-production-password"
ADMIN_SESSION_SECRET="replace-with-random-32-byte-or-longer-secret"

# Public, non-secret site origin.
# Local development: http://localhost:3000
# Current Vercel production: https://localtrip-ax.vercel.app
# If a custom domain is connected, update this to the canonical public origin.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

